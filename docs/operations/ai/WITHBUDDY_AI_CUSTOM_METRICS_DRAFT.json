        "type": "text",
        "title": "SCRUM-564 Contract",
        "gridPos": { "h": 5, "w": 24, "x": 0, "y": 0 },
        "options": {
          "mode": "markdown",
          "content": "Prompt Cache Grafana draft for `SCRUM-564`.\\n\\nPrimary metric now exposed by backend:\\n- `withbuddy_prompt_cache_requests_total{namespace,result,source}`\\n\\nSupporting cache resilience metrics already available in backend:\\n- `cache_redis_requests_total{op,result}`\\n- `cache_redis_fallback_total{op,result}`\\n- `cache_redis_circuit_open`\\n- `cache_redis_fallback_tokens`"
        }
      },
      {
        "type": "stat",
        "title": "Prompt Cache Hit Rate (5m)",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 5 },
        "datasource": { "type": "prometheus", "uid": "cfmoqr81uwdtse" },
        "targets": [
          {
            "expr": "100 * sum(rate(withbuddy_prompt_cache_requests_total{result=\"hit\"}[5m])) / clamp_min(sum(rate(withbuddy_prompt_cache_requests_total[5m])), 0.0001)",
            "legendFormat": "hit_rate",
            "refId": "A"
          }
        ],
        "options": {
          "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
          "orientation": "auto",
          "textMode": "value_and_name",
          "colorMode": "value",
          "graphMode": "none",
          "justifyMode": "center"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "decimals": 2,
            "thresholds": {
              "mode": "absolute",
              "steps": [
