      {
        "type": "timeseries",
        "title": "AI CPU Usage",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
        "datasource": { "type": "prometheus", "uid": "cfmoqr81uwdtse" },
        "targets": [
          {
            "expr": "rate(process_cpu_seconds_total{job=\"withbuddy_ai_metrics\",instance=\"10.2.2.242:8000\"}[5m])",
