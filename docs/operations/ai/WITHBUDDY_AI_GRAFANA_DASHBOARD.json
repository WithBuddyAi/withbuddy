        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "custom": { "drawStyle": "line", "lineWidth": 2, "showPoints": "never", "spanNulls": true }
          },
          "overrides": []
        }
      },
      {
        "type": "timeseries",
        "title": "AI Memory Usage",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
        "datasource": { "type": "prometheus", "uid": "cfmoqr81uwdtse" },
        "targets": [
          {
            "expr": "process_resident_memory_bytes{job=\"withbuddy_ai_metrics\",instance=\"10.2.2.242:8000\"}",
            "legendFormat": "resident",
            "refId": "A"
          }
        ],
        "options": {
          "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true },
